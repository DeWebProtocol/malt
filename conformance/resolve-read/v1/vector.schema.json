{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dewebprotocol.github.io/malt/conformance/resolve-read/v1/vector.schema.json",
  "title": "MALT Resolve/Read Conformance Vector v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "operation",
    "backend",
    "category",
    "verification",
    "expected"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "operation": {
      "enum": ["resolve", "read"]
    },
    "backend": {
      "enum": ["none", "kzg", "ipa"]
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "verification": {
      "type": "object"
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid"],
      "properties": {
        "valid": {
          "type": "boolean"
        }
      }
    }
  }
}
