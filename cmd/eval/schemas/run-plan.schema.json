{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dewebprotocol.dev/malt/eval/run-plan.schema.json",
  "title": "MALT evaluation run plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["suites"],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "config": {
            "type": "object"
          }
        }
      }
    }
  }
}
