{
  "rpc": {
    "listen": "127.0.0.1:4317"
  },
  "state": {
    "root_dir": "~/.malt/state",
    "kvstore": {
      "type": "badger",
      "path": "kv"
    },
    "arctable": {
      "type": "versioned"
    },
    "lineage": {
      "enabled": true
    }
  },
  "structure": {
    "default_backend": "kzg"
  },
  "cas": {
    "mode": "embedded-mock",
    "timeout": "30s",
    "embedded_mock": {
      "enabled": true,
      "listen": "127.0.0.1:4318"
    }
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
