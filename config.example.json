{
  "rpc": {
    "listen": "127.0.0.1:4317",
    "cors_allowed_origins": []
  },
  "state": {
    "root_dir": "~/.malt/state",
    "kvstore": {
      "type": "badger",
      "path": "kv"
    },
    "arctable": {
      "type": "versioned"
    }
  },
  "structure": {
    "default_backend": "kzg"
  },
  "cas": {
    "mode": "external",
    "base_url": "http://127.0.0.1:4318",
    "timeout": "30s"
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
