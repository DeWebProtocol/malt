{
  "rpc": {
    "listen": "127.0.0.1:4317",
    "cors_allowed_origins": [
      "http://127.0.0.1:5173",
      "http://localhost:5173",
      "http://127.0.0.1:5174",
      "http://localhost:5174",
      "http://127.0.0.1:4173",
      "http://localhost:4173",
      "http://127.0.0.1:4174",
      "http://localhost:4174",
      "https://dewebprotocol.dev",
      "https://dewebprotocol.github.io"
    ]
  },
  "state": {
    "root_dir": "~/.malt/state",
    "kvstore": {
      "type": "badger",
      "path": "kv"
    },
    "arctable": {
      "type": "versioned"
    }
  },
  "structure": {
    "default_backend": "kzg"
  },
  "cas": {
    "mode": "embedded-mock",
    "timeout": "30s",
    "embedded_mock": {
      "enabled": true,
      "listen": "127.0.0.1:4318"
    }
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
