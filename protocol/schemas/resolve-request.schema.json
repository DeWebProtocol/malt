{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deweb.world/schemas/malt/resolve/v0alpha1/request.schema.json",
  "title": "MALT Resolve Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "root", "segments"],
  "properties": {
    "profile": {"const": "malt.resolve/v0alpha1"},
    "root": {"type": "string", "minLength": 1},
    "segments": {"type": "array", "items": {"type": "string", "minLength": 1, "pattern": "^[^/]+$"}}
  }
}
