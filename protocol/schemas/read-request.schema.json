{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deweb.world/schemas/malt/read/v0alpha1/request.schema.json",
  "title": "MALT Read Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "root", "query"],
  "properties": {
    "profile": {"const": "malt.read/v0alpha1"},
    "root": {"type": "string", "minLength": 1},
    "query": {"$ref": "#/$defs/query"}
  },
  "$defs": {
    "segments": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "pattern": "^[^/]+$"}},
    "query": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["kind", "segments"], "properties": {"kind": {"const": "map_key"}, "segments": {"$ref": "#/$defs/segments"}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "index"], "properties": {"kind": {"const": "list_index"}, "index": {"type": "integer", "minimum": 0}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "start"], "properties": {"kind": {"const": "list_range"}, "start": {"type": "integer", "minimum": 0}, "end": {"type": "integer", "minimum": 1}}}
      ]
    }
  }
}
