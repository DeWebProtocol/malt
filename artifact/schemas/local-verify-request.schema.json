{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deweb.world/schemas/malt/artifact/v0alpha2/local-verify-request.schema.json",
  "title": "MALT Local Verify Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "trusted_root", "expected", "artifact"],
  "properties": {
    "profile": {"const": "malt.artifact/v0alpha2"},
    "trusted_root": {"type": "string", "minLength": 1},
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation", "query"],
      "properties": {
        "operation": {"enum": ["resolve", "resolve_payload", "prove"]},
        "query": {"$ref": "artifact.schema.json#/$defs/query"},
        "target": {"type": "string", "minLength": 1}
      }
    },
    "artifact": {"$ref": "artifact.schema.json"}
  }
}
